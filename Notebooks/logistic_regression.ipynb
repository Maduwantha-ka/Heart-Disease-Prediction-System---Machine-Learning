     ]
    }
   ],
   "source": [
    "#confusion matrix\n",
    "cm_lr = confusion_matrix(y_test, lr_pred)\n",
    "tn, fp, fn, tp = cm_lr.ravel()\n",
    "\n",
    "plt.figure(figsize=(6, 5))\n",
    "sns.heatmap(cm_lr, annot=True, fmt='d', cmap='Blues',\n",
    "            xticklabels=['Predicted: No Disease', 'Predicted: Disease'],\n",
    "            yticklabels=['Actual: No Disease',    'Actual: Disease'])\n",
    "plt.title('Confusion Matrix — Logistic Regression', fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig('confusion_matrix_LR.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(f'TN={tn}  FP={fp}  FN={fn}  TP={tp}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "4f62fa0f-b311-4524-9db3-8f8f169a87b3",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
